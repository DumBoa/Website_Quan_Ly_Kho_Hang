          const y = chartHeight - 30;
          
          ctx.fillStyle = '#3b82f6';
          ctx.fillRect(x - barWidth / 2, y - barHeight, barWidth, barHeight);
          
          // Labels
          ctx.fillStyle = '#1e293b';
          ctx.font = 'bold 13px Inter';
          ctx.textAlign = 'center';
